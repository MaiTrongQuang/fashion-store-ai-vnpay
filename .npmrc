# pnpm configuration for Next.js project
# Hoist all dependencies to root node_modules for Next.js compatibility
shamefully-hoist=true

# Auto-install peer dependencies
auto-install-peers=true

# Use strict peer dependencies (warn instead of error)
strict-peer-dependencies=false

# Store directory (use default global store for disk space efficiency)
# store-dir=~/.pnpm-store

# Lockfile settings
lockfile=true
prefer-frozen-lockfile=true
